# ─── Database ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/orderworder?retryWrites=true&w=majority

# ─── NextAuth ───────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-random-string-at-least-32-chars
# OTP_SECRET — optional, falls back to NEXTAUTH_SECRET; generate with: openssl rand -hex 32
OTP_SECRET=your_otp_secret

# ─── AI Providers (at least one required for Jarvis) ───────
# Groq: https://console.groq.com/keys
AI_GROQ_KEY=gsk_your_groq_api_key
# Cerebras: https://cloud.cerebras.ai/
AI_CEREBRAS_KEY=your_cerebras_api_key
# Google Gemini (OpenAI-compatible): https://aistudio.google.com/apikey
AI_GOOGLE_KEY=AIza_your_google_api_key
# SiliconFlow: https://cloud.siliconflow.com/ apikey
AI_SILICONFLOW_KEY=your_siliconflow_api_key
# HuggingFace: https://huggingface.co/settings/tokens
AI_HUGGINGFACE_KEY=your_huggingface_api_key

# ─── Upstash Redis (rate limiting & cache) ──────────────────
# Get from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# ─── Razorpay (payments) ────────────────────────────────────
# Get from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_ACCOUNT_NUMBER=your_razorpay_account_number # Required for settlements/payouts

# ─── Stripe (international/USD support, alongside Razorpay) ─
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_billing_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
# Stripe Billing — SaaS subscription price IDs (create in Stripe Products & Prices)
STRIPE_PRICE_PRO_IN=price_your_pro_in_price_id
STRIPE_PRICE_PRO_USD=price_your_pro_usd_price_id
STRIPE_PRICE_ENT_IN=price_your_ent_in_price_id
STRIPE_PRICE_ENT_USD=price_your_ent_usd_price_id

# ─── n8n (workflow automation) ──────────────────────────────
# Get from your n8n instance
N8N_WEBHOOK_URL=https://n8n.yourdomain.com/webhook
N8N_WEBHOOK_SECRET=change-this-to-a-random-string-at-least-32-chars
N8N_WEBHOOK_TOKEN=your_bearer_token # Optional: second auth factor
N8N_API_KEY=your_n8n_api_key # Optional: for workflow management
N8N_INBOUND_ALLOWED_IPS=203.0.113.10 # Optional: comma-separated IP allowlist

# ─── Sentry (error monitoring) ─────────────────────────────
# Get from https://sentry.io
SENTRY_DSN=https://your-dsn@sentry.io/your-project
SENTRY_AUTH_TOKEN=your_auth_token

# ─── ElevenLabs (Voice TTS) ────────────────────────────────
# ELEVENLABS_API_KEY — optional, only used when a restaurant opts into premium TTS
# When empty, browser SpeechSynthesis is used (zero-cost)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── WhatsApp Cloud API ────────────────────────────────────
# Get from Meta Business Suite > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
# Optional: self-hosted OpenWA for free WhatsApp (https://github.com/open-wa/wa-automate)
OPENWA_API_URL=http://localhost:8080

# ─── Cloudflare R2 (object storage for menu images, 3D models) ──
# Get from https://cloudflare.com
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret
R2_BUCKET_NAME=orderworder
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
NEXT_PUBLIC_R2_MODELS_URL=https://pub-xxxx.r2.dev/models/food # 3D GLB models CDN URL

# ─── Twilio (inbound IVR + outbound order-ready calls) ─────
# Optional — leave blank to disable IVR. Get from https://twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_STAFF_NUMBER= # forwarded to this number when caller presses 2

# ─── Demo/Seed Data ─────────────────────────────────────────
# Set to "true" to enable /api/refreshDemoData in production
DEMO_MODE=false

# ─── Public URL (for QR codes) ─────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3000

# ─── CORS (middleware) ─────────────────────────────────────
# Comma-separated origins allowed for public API CORS
# In production: set to your dashboard domain + wildcard subdomain
ALLOWED_ORIGINS=https://app.orderworder.com,https://*.orderworder.com

# ─── Resend (transactional email) ────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# ─── Encryption (tenant-level secret rotation) ──────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET=your_encryption_secret

# ─── Cron Jobs ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_job_secret

# ─── Subdomain Tenancy ──────────────────────────────────────
ROOT_DOMAIN=orderworder.com

# ─── Inngest (background queue) ──────────────────────────────
# Get from https://app.inngest.com
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key
INNGEST_API_ENDPOINT=https://www.inngest.com/event/your-app-id

# ─── Optional: Doppler (for managed env in dev/build) ─────
# DOPPLER_TOKEN=your_doppler_token
