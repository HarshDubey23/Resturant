# ─── Database ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/orderworder?retryWrites=true&w=majority

# ─── NextAuth ───────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-random-string-at-least-32-chars

# ─── AI Providers (at least one required for Jarvis) ───────
# Groq: https://console.groq.com/keys
AI_GROQ_KEY=gsk_your_groq_api_key
# Cerebras: https://cloud.cerebras.ai/
AI_CEREBRAS_KEY=your_cerebras_api_key
# Google Gemini (OpenAI-compatible): https://aistudio.google.com/apikey
AI_GOOGLE_KEY=AIza_your_google_api_key
# SiliconFlow: https://cloud.siliconflow.com/ apikey
AI_SILICONFLOW_KEY=your_siliconflow_api_key

# ─── Upstash Redis (rate limiting & cache) ──────────────────
# Get from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# ─── Razorpay (payments) ────────────────────────────────────
# Get from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_secret

# ─── Sentry (error monitoring) ─────────────────────────────
# Get from https://sentry.io
SENTRY_DSN=https://your-dsn@sentry.io/your-project
SENTRY_AUTH_TOKEN=your_auth_token

# ─── ElevenLabs (Voice TTS) ────────────────────────────────
# Get from https://elevenlabs.io
ELEVENLABS_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── WhatsApp Cloud API ────────────────────────────────────
# Get from Meta Business Suite > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token

# ─── Cloudflare R2 (object storage for menu images, 3D models) ──
# Get from https://cloudflare.com
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret
R2_BUCKET_NAME=orderworder
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─── Demo/Seed Data ─────────────────────────────────────────
# Set to "true" to enable /api/refreshDemoData in production
DEMO_MODE=false

# ─── Public URL (for QR codes) ─────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3000

# ─── Optional: Doppler (for managed env in dev/build) ─────
# DOPPLER_TOKEN=your_doppler_token