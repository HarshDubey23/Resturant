# ─────────────────────────────────────────────────────────────────────────────
# OrderWorder — Canonical Environment Variable Reference (.env.example)
# ─────────────────────────────────────────────────────────────────────────────
# This file is the SINGLE SOURCE OF TRUTH for every env var the OrderWorder
# codebase actually reads. It is generated by scanning every `process.env.*`
# reference under `src/`, `scripts/`, `middleware.ts`, `next.config.ts`, and
# `sentry.{client,edge,server}.config.ts` (see docs/DEPLOYMENT_RUNBOOK.md).
#
# HOW TO USE
#   1. cp .env.example .env.local
#   2. Fill in every REQUIRED value (and the OPTIONALS you need)
#   3. Restart the dev server: `bun run dev`
#   4. For Vercel: copy the same values into Project → Settings → Environment
#      Variables (mark Production-only for `*_SECRET`, `MONGODB_URI`, `CRON_SECRET`).
#
# RULES
#   - All secrets live in env vars only. No secrets in code or commits.
#   - `.env*` files (except this one) are gitignored (see `.gitignore`).
#   - Webhook secrets (`N8N_WEBHOOK_SECRET`, `RAZORPAY_WEBHOOK_SECRET`,
#     `STRIPE_WEBHOOK_SECRET`) are verified via HMAC + `timingSafeEqual`
#     (constant-time) — NEVER via string equality.
#   - Generate random secrets with: `openssl rand -hex 32` (or `-base64 32`).
#
# CONVENTIONS USED BELOW
#   # Required: yes/no | Used by: <file> | Description
#   KEY=value
#
# NOTE: Section 9 ("E-Invoice / NIC") and the `EINVOICE_ENABLED` flag are
# introduced by Phase 2 Task 2-C (`src/utils/gst/nicEinvoice.ts`). The flags
# are documented here so operators can pre-stage them; the code path is a no-op
# (mock IRN) until `EINVOICE_ENABLED=true`.
# ─────────────────────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════════════════════════════════════
# Database (MongoDB Atlas)
# ═══════════════════════════════════════════════════════════════════════════
# Required: yes | Used by: src/utils/database/connect.ts, scripts/seed-demo.ts, scripts/migrate-*.ts, scripts/sync-indexes.ts, scripts/make-platform-admin.ts, scripts/migrate-base64-to-r2.ts | Description: MongoDB connection string. Atlas free tier (M0) is sufficient for demo. Replace <password> and <dbname>. IP allowlist must include your hosting provider IPs (0.0.0.0/0 for Vercel).
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/orderworder?retryWrites=true&w=majority


# ═══════════════════════════════════════════════════════════════════════════
# Auth (NextAuth)
# ═══════════════════════════════════════════════════════════════════════════
# Required: yes | Used by: src/utils/helper/authHelper.ts | Description: NextAuth v4 JWT signing secret. Generate with `openssl rand -base64 32`. Must be ≥32 chars.
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string

# Required: yes | Used by: middleware.ts, src/app/api/payment/stripe/create-checkout/route.ts, src/utils/whatsapp/notifications.ts | Description: The canonical app origin (e.g. http://localhost:3050 in dev, https://your-domain.com in prod). Used for CORS default, redirects, absolute links in WhatsApp notifications, Stripe checkout success_url.
NEXTAUTH_URL=http://localhost:3050

# Required: no | Used by: src/utils/helper/otp.ts | Description: HMAC secret for signing OTP verification tokens. If unset, falls back to NEXTAUTH_SECRET. Generate separately with `openssl rand -hex 32` for defense-in-depth.
OTP_SECRET=

# Required: no | Used by: src/utils/helper/crypto.ts | Description: Encryption secret for tenant-level field encryption. If unset, falls back to NEXTAUTH_SECRET. Generate separately with `openssl rand -hex 32`.
ENCRYPTION_SECRET=

# Required: yes | Used by: src/app/api/auth/send-otp/route.ts (in dev), middleware.ts (dev branch) | Description: Set by the runtime. Never set this manually in prod. In dev, OTP send returns the code in the response body for testing.
NODE_ENV=development


# ═══════════════════════════════════════════════════════════════════════════
# Payments — Razorpay (India / INR)
# ═══════════════════════════════════════════════════════════════════════════
# Required: no | Used by: src/utils/payment/razorpay.ts, src/app/api/payment/create-order/route.ts, src/app/api/payment/upi-autodebit/register/route.ts, src/app/api/health/route.ts | Description: Razorpay Key ID (rzp_test_... or rzp_live_...). Leave blank to disable online payments (cash still works).
RAZORPAY_KEY_ID=

# Required: no | Used by: src/utils/payment/razorpay.ts, src/app/api/health/route.ts | Description: Razorpay Key Secret (server-side). Pair with RAZORPAY_KEY_ID.
RAZORPAY_KEY_SECRET=

# Required: no | Used by: src/app/api/payment/route/settle/route.ts, src/utils/queue/daily-settlement.ts | Description: Razorpay Route account number for settlement/payout API. Required only if you use the daily settlement cron.
RAZORPAY_ACCOUNT_NUMBER=

# Required: no | Used by: src/app/api/payment/webhook/route.ts | Description: Razorpay webhook signing secret (from Razorpay Dashboard → Webhooks). Required for signature verification; without it, payment webhook returns 500.
RAZORPAY_WEBHOOK_SECRET=


# ═══════════════════════════════════════════════════════════════════════════
# Payments — Stripe (International / USD; also powers SaaS billing)
# ═══════════════════════════════════════════════════════════════════════════
# Required: no | Used by: src/utils/payment/stripe.ts, src/app/api/health/route.ts | Description: Stripe secret key (sk_test_... or sk_live_...). Leave blank to disable Stripe.
STRIPE_SECRET_KEY=

# Required: no | Used by: src/app/api/payment/stripe/webhook/route.ts, src/app/api/billing/webhook/route.ts | Description: Stripe webhook signing secret (whsec_...) for the /api/payment/stripe/webhook AND /api/billing/webhook endpoints. Two endpoints = two webhook secrets (set this to the secret of whichever endpoint you activate first, and add the second separately).
STRIPE_WEBHOOK_SECRET=

# Required: no | Used by: src/utils/stripe/client.ts | Description: Stripe publishable key (pk_test_... or pk_live_...). Public — safe to expose to the browser. Required for client-side Stripe.js.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Required: no | Used by: src/app/api/billing/webhook/route.ts | Description: Stripe Price ID for the Pro plan (INR). Create in Stripe Products & Prices. Required for SaaS subscription billing.
STRIPE_PRICE_PRO_IN=

# Required: no | Used by: src/app/api/billing/webhook/route.ts | Description: Stripe Price ID for the Pro plan (USD).
STRIPE_PRICE_PRO_USD=

# Required: no | Used by: src/app/api/billing/webhook/route.ts | Description: Stripe Price ID for the Enterprise plan (INR).
STRIPE_PRICE_ENT_IN=

# Required: no | Used by: src/app/api/billing/webhook/route.ts | Description: Stripe Price ID for the Enterprise plan (USD).
STRIPE_PRICE_ENT_USD=


# ═══════════════════════════════════════════════════════════════════════════
# WhatsApp (Meta Cloud API — primary path)
# ═══════════════════════════════════════════════════════════════════════════
# Required: no | Used by: src/utils/whatsapp/meta.ts, src/utils/whatsapp/index.ts | Description: Meta WhatsApp Cloud API Phone Number ID (from Meta Business Suite → WhatsApp → API Setup). Pair with WHATSAPP_ACCESS_TOKEN.
WHATSAPP_PHONE_NUMBER_ID=

# Required: no | Used by: src/utils/whatsapp/meta.ts, src/utils/whatsapp/index.ts | Description: Meta WhatsApp Cloud API permanent access token (system-user token). Treat as a secret — never expose client-side.
WHATSAPP_ACCESS_TOKEN=

# Required: no | Used by: src/utils/whatsapp/openwa.ts, src/utils/whatsapp/index.ts | Description: Self-hosted OpenWA instance URL (e.g. http://localhost:8080). When set, OpenWA takes precedence over the Meta Cloud API. Leave blank to use Meta. See docs/whatsapp-openwa.md.
OPENWA_API_URL=


# ═══════════════════════════════════════════════════════════════════════════
# Twilio (inbound IVR + outbound order-ready calls)
# ═══════════════════════════════════════════════════════════════════════════
# Required: no | Used by: src/utils/twilio/index.ts | Description: Twilio Account SID. Leave all four Twilio vars blank to disable IVR. Phone ordering will still work via WhatsApp + web.
TWILIO_ACCOUNT_SID=

# Required: no | Used by: src/utils/twilio/index.ts | Description: Twilio Auth Token.
TWILIO_AUTH_TOKEN=

# Required: no | Used by: src/utils/twilio/index.ts | Description: Twilio phone number (E.164 format, e.g. +14155551234) for outbound calls.
TWILIO_FROM_NUMBER=

# Required: no | Used by: src/app/api/twilio/ivr/gather/route.ts | Description: Staff forwarding number — when a caller presses 2 during IVR, the call forwards here. E.164 format.
TWILIO_STAFF_NUMBER=


# ═══════════════════════════════════════════════════════════════════════════
# Email (Resend)
# ═══════════════════════════════════════════════════════════════════════════
# Required: no | Used by: src/utils/email/index.ts, src/utils/queue/weekly-digest.ts | Description: Resend API key (re_...). Powers password-reset + signup-verify transactional emails and the weekly owner digest. If unset, email send is silently skipped (logs a warning).
RESEND_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════
# AI Providers (one+ required for Jarvis AI chat / analytics insights)
# All AI_*_KEY vars are read dynamically in src/utils/ai/config.ts via
# process.env[`AI_${platform.toUpperCase()}_KEY`]. Provider failover chain
# is Groq → Cerebras → Google → SiliconFlow → HuggingFace.
# Per-tenant overrides are stored in the aiConfig collection (Settings → AI Keys).
# ═══════════════════════════════════════════════════════════════════════════
# Required: no (at least one recommended) | Used by: src/utils/ai/config.ts, src/app/api/admin/ai-keys/route.ts, src/utils/ai/switcher.ts | Description: Groq API key (gsk_...). Recommended primary — fastest inference, generous free tier. Get from https://console.groq.com/keys
AI_GROQ_KEY=

# Required: no | Used by: src/utils/ai/config.ts | Description: Cerebras API key. https://cloud.cerebras.ai/
AI_CEREBRAS_KEY=

# Required: no | Used by: src/utils/ai/config.ts | Description: Google Gemini API key (AIza_...). https://aistudio.google.com/apikey
AI_GOOGLE_KEY=

# Required: no | Used by: src/utils/ai/config.ts | Description: SiliconFlow API key (DeepSeek models). https://cloud.siliconflow.com/
AI_SILICONFLOW_KEY=

# Required: no | Used by: src/utils/ai/config.ts | Description: HuggingFace API token. https://huggingface.co/settings/tokens
AI_HUGGINGFACE_KEY=

# Required: no | Used by: src/app/api/voice/tts/route.ts | Description: ElevenLabs API key for premium TTS. If unset, voice ordering falls back to the browser SpeechSynthesis API (zero-cost). https://elevenlabs.io
ELEVENLABS_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════
# n8n (workflow automation — Phase 3 killer features)
# Outbound: app → n8n via triggerN8nWorkflow (HMAC-signed POST).
# Inbound: n8n → app at /api/webhooks/n8n (HMAC-verified, optional IP allowlist).
# ═══════════════════════════════════════════════════════════════════════════
# Required: no | Used by: src/lib/n8n/env.ts, src/lib/n8n/client.ts | Description: Base URL of your n8n webhook listener, e.g. https://n8n.yourdomain.com/webhook. The client appends `/{eventType}` to this. Leave both N8N_WEBHOOK_URL and N8N_WEBHOOK_SECRET blank to disable outbound workflow triggers (app degrades gracefully).
N8N_WEBHOOK_URL=

# Required: no (required if N8N_WEBHOOK_URL is set) | Used by: src/lib/n8n/env.ts, src/lib/n8n/client.ts, src/app/api/webhooks/n8n/route.ts | Description: HMAC-SHA256 secret shared between this app and n8n. Used to sign outbound payloads (X-N8N-Signature header) and verify inbound webhook bodies. Generate with `openssl rand -hex 32`. MUST be the same value configured as N8N_WEBHOOK_SECRET in the n8n environment (see docs/n8n/README.md).
N8N_WEBHOOK_SECRET=

# Required: no | Used by: src/lib/n8n/env.ts, src/lib/n8n/client.ts | Description: Optional Bearer token for a second auth factor on outbound calls to n8n (sent as `Authorization: Bearer <token>`).
N8N_WEBHOOK_TOKEN=

# Required: no | Used by: src/lib/n8n/env.ts | Description: Optional n8n API key for workflow management (import/update via API). Not currently used by the runtime but defined in the env schema for future use.
N8N_API_KEY=

# Required: no | Used by: src/lib/n8n/env.ts, src/app/api/webhooks/n8n/route.ts | Description: Comma-separated IP allowlist for the inbound /api/webhooks/n8n endpoint. If unset, ALL IPs are allowed (HMAC still required). Recommended in prod: set to your n8n server's egress IP(s). Example: 203.0.113.10,203.0.113.11
N8N_INBOUND_ALLOWED_IPS=


# ═══════════════════════════════════════════════════════════════════════════
# Storage — Cloudflare R2 (S3-compatible; menu images, logos, 3D models)
# Endpoint is derived from R2_ACCOUNT_ID; R2_ENDPOINT is NOT used by the code.
# When R2 is unset, uploads fall back to base64 in MongoDB (works for demo).
# ═══════════════════════════════════════════════════════════════════════════
# Required: no | Used by: src/utils/storage/r2.ts | Description: Cloudflare account ID. Used to derive the S3 endpoint (`https://<account_id>.r2.cloudflarestorage.com`).
R2_ACCOUNT_ID=

# Required: no | Used by: src/utils/storage/r2.ts | Description: R2 access key ID (from Cloudflare Dashboard → R2 → Manage R2 API Tokens).
R2_ACCESS_KEY_ID=

# Required: no | Used by: src/utils/storage/r2.ts | Description: R2 secret access key (shown once on token creation).
R2_SECRET_ACCESS_KEY=

# Required: no | Used by: src/utils/storage/r2.ts | Description: R2 bucket name (e.g. `orderworder`).
R2_BUCKET_NAME=

# Required: no | Used by: src/utils/storage/r2.ts | Description: Public CDN base URL for the R2 bucket (e.g. https://pub-xxxx.r2.dev). Used to construct public image URLs returned to the client.
R2_PUBLIC_URL=


# ═══════════════════════════════════════════════════════════════════════════
# Sentry / GlitchTip (error monitoring)
# ═══════════════════════════════════════════════════════════════════════════
# Required: no | Used by: sentry.client.config.ts, sentry.edge.config.ts, sentry.server.config.ts | Description: Sentry (or GlitchTip) project DSN. If unset, errors are logged to console only. SDK is enabled only when NODE_ENV=production.
SENTRY_DSN=


# ═══════════════════════════════════════════════════════════════════════════
# Redis — Upstash (rate limiting, OTP cache, subdomain tenancy cache)
# IMPORTANT: The code reads UPSTASH_REDIS_REST_URL — NOT `REDIS_URL`.
# If both are unset, an in-memory fallback is used (single-instance only).
# ═══════════════════════════════════════════════════════════════════════════
# Required: no (strongly recommended for Vercel/multi-instance) | Used by: src/utils/database/redis.ts (via @upstash/redis), src/utils/helper/rateLimit.ts | Description: Upstash Redis REST URL (e.g. https://xxx-xxx.upstash.io). Get from https://console.upstash.com. The `@upstash/redis` client speaks REST, so this is NOT a `rediss://` connection string.
UPSTASH_REDIS_REST_URL=

# Required: no (required if UPSTASH_REDIS_REST_URL is set) | Used by: src/utils/database/redis.ts | Description: Upstash Redis REST token. Auto-generated when you create the database.
UPSTASH_REDIS_REST_TOKEN=


# ═══════════════════════════════════════════════════════════════════════════
# Feature Flags
# ═══════════════════════════════════════════════════════════════════════════
# Required: no | Used by: src/app/api/refreshDemoData/route.ts, src/utils/helper/authHelper.ts | Description: When `true`, enables /api/refreshDemoData (mass demo re-seed) and skips OTP for the demo restaurant in NON-PRODUCTION only. Demo auth is hard-disabled in production regardless of this flag. MUST be `false` (or unset) in production.
DEMO_MODE=false

# Required: no | Used by: (Phase 2 Task 2-C — src/utils/gst/nicEinvoice.ts, src/app/api/invoice/generate/route.ts) | Description: Master switch for NIC e-invoice IRN generation. When `false`, the app produces GST-compliant invoices without an IRN (mock fallback). Flip to `true` only after NIC sandbox testing passes. See docs/EINVOICE_GO_LIVE.md.
EINVOICE_ENABLED=false

# Required: no | Used by: (Phase 2 Task 2-C — src/utils/gst/nicEinvoice.ts) | Description: NIC environment: `sandbox` or `prod`. Start in sandbox. Switch to `prod` only after go-live sign-off. See docs/EINVOICE_GO_LIVE.md.
NIC_ENV=sandbox


# ═══════════════════════════════════════════════════════════════════════════
# NIC E-Invoice (India B2B e-invoicing)
# Required only when EINVOICE_ENABLED=true. See docs/EINVOICE_GO_LIVE.md.
# Sandbox: https://einvoice-1-sandbox.nic.in  |  Prod: https://einvoice-1.nic.in
# ═══════════════════════════════════════════════════════════════════════════
# Required: no | Used by: (Phase 2 Task 2-C — src/utils/gst/nicEinvoice.ts) | Description: NIC Application Software Number (ASN) — issued on NIC portal registration. Used for the NIC auth token request.
NIC_ASN=

# Required: no | Used by: (Phase 2 Task 2-C — src/utils/gst/nicEinvoice.ts) | Description: NIC portal username (typically the GSTIN-registered user account).
NIC_USER=

# Required: no | Used by: (Phase 2 Task 2-C — src/utils/gst/nicEinvoice.ts) | Description: NIC portal password.
NIC_PASSWORD=

# Required: no | Used by: (Phase 2 Task 2-C — src/utils/gst/nicEinvoice.ts) | Description: The restaurant's own GSTIN used as the issuer for IRN generation.
NIC_GSTIN=


# ═══════════════════════════════════════════════════════════════════════════
# App — Public URL, CORS, Subdomain Tenancy, Crons
# ═══════════════════════════════════════════════════════════════════════════
# Required: yes | Used by: src/app/api/admin/tables/route.ts, src/app/api/billing/checkout/route.ts, src/app/api/billing/portal/route.ts, src/app/api/auth/setup-tables/route.ts, src/utils/email/templates/*, src/components/Settings/SettingsTables.tsx, src/app/api/payment/stripe/create-checkout/route.ts | Description: Public-facing base URL (e.g. http://localhost:3050, https://your-domain.com). Encoded into table QR codes, password-reset links, Stripe success/cancel URLs. CRITICAL for production.
NEXT_PUBLIC_URL=http://localhost:3050

# Required: no | Used by: src/utils/seo/constants.ts | Description: SEO canonical site URL (defaults to https://orderworder.ritik.me). Set to your production domain for correct sitemap/opengraph metadata.
NEXT_PUBLIC_SITE_URL=https://orderworder.com

# Required: no | Used by: src/app/api/admin/tables/route.ts, src/app/api/auth/setup-tables/route.ts | Description: Auto-set by Vercel (e.g. your-project.vercel.app). Used as a fallback origin when NEXT_PUBLIC_URL is missing.
# VERCEL_URL= (set automatically by Vercel runtime)

# Required: no | Used by: middleware.ts | Description: Comma-separated CORS allow-list for public API routes (/api/menu, /api/feedback, /api/health). In dev, defaults to "*". In prod, defaults to NEXTAUTH_URL if unset. Example: https://app.orderworder.com,https://www.orderworder.com
ALLOWED_ORIGINS=

# Required: no | Used by: middleware.ts | Description: Root domain for subdomain tenancy routing (e.g. orderworder.com). Subdomains of this domain rewrite to /<slug>/... Set to your apex domain in prod.
ROOT_DOMAIN=orderworder.com

# Required: no (recommended) | Used by: src/app/api/cron/settle/route.ts, src/app/api/cron/birthday/route.ts, src/app/api/whatsapp/campaigns/process-scheduled/route.ts | Description: Bearer-token secret for Vercel Cron Job auth. Each cron endpoint expects `Authorization: Bearer <CRON_SECRET>`. Generate with `openssl rand -hex 32`.
CRON_SECRET=


# ═══════════════════════════════════════════════════════════════════════════
# Background Queue — Inngest (abandoned-cart, birthday, settlement, weekly digest)
# ═══════════════════════════════════════════════════════════════════════════
# Required: no | Used by: src/utils/queue/inngest-client.ts | Description: Inngest event key for enqueuing background jobs. Get from https://app.inngest.com. If unset, the Inngest client is constructed with an empty key (jobs silently no-op).
INNGEST_EVENT_KEY=


# ═══════════════════════════════════════════════════════════════════════════
# Ghost / Removed Variables (referenced in legacy docs but NOT read by code)
# ─────────────────────────────────────────────────────────────────────────────
# The following were present in the OLD .env.example and DEPLOYMENT.md but are
# NOT referenced anywhere under src/, scripts/, middleware.ts, next.config.ts,
# or sentry.*.config.ts. They have been REMOVED from this canonical file. Do
# NOT set them — they do nothing.
#
#   REDIS_URL                  → code reads UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
#   WHATSAPP_BASE_URL          → code reads OPENWA_API_URL
#   WHATSAPP_API_KEY           → not used; OpenWA uses no API key (token in URL)
#   R2_ENDPOINT                → code derives endpoint from R2_ACCOUNT_ID
#   NEXT_PUBLIC_R2_MODELS_URL  → not currently read by any component
#   SENTRY_AUTH_TOKEN          → used only at CI build time by @sentry/webpack-plugin (not by runtime); set in CI secrets, not here
#   ELEVENLABS_VOICE_ID        → code uses ElevenLabs default voice; override per-request if needed
#   INNGEST_SIGNING_KEY        → read implicitly by the @inngest/next serve() middleware; set in prod only if you run Inngest Cloud
#   INNGEST_API_ENDPOINT       → same as above
#   DOPPLER_TOKEN              → only used by the dev:doppler npm script (Doppler CLI injects env at runtime)
# ─────────────────────────────────────────────────────────────────────────────
